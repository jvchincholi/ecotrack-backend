DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ecotrack_user
DB_PASSWORD=ecotrack_dev_2026
DB_NAME=ecotrack_db

# JWT Configuration for Authentication
# JWT_SECRET: Must be at least 32 characters, use a strong random string in production
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_required

# Token Expiration Times (in seconds)
JWT_EXPIRATION=3600                    # Access token: 1 hour
JWT_REFRESH_EXPIRATION=604800          # Refresh token: 7 days

# Optional: Environment name for logging
NODE_ENV=development                   # development, staging, production